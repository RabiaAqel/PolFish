# ============================================================
# PolFish / MiroFish Configuration
# ============================================================

# --- Main LLM (fallback for simulation + report stages) ---
LLM_API_KEY=your-openai-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# --- DeepSeek (preprocessing: ontology, graph, profiles) ---
# Sign up free: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key

# --- Gemini (optional, for agent profiles) ---
# Sign up free: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key

# --- Anthropic Claude (optional, for simulation) ---
# ANTHROPIC_API_KEY=your-anthropic-key

# --- Mistral (optional) ---
# MISTRAL_API_KEY=your-mistral-key

# --- Groq (optional, fast inference for open-source models) ---
# Sign up free: https://console.groq.com
# GROQ_API_KEY=your-groq-key

# --- Zep (knowledge graph memory) ---
# Sign up free: https://app.getzep.com
ZEP_API_KEY=your-zep-key

# ============================================================
# Stage-specific model overrides (optional)
# Default: DeepSeek for preprocessing, GPT-4o for simulation/report
# ============================================================
# ONTOLOGY_MODEL=deepseek-chat
# GRAPH_MODEL=deepseek-chat
# PROFILES_MODEL=gemini-2.5-flash-lite
# SIMULATION_MODEL=gpt-4o
# REPORT_MODEL=gpt-4o

# ============================================================
# Example configurations:
# ============================================================
#
# CHEAPEST (~$0.02/prediction, all DeepSeek):
#   SIMULATION_MODEL=deepseek-chat
#   REPORT_MODEL=deepseek-chat
#
# BALANCED (~$0.42/prediction, recommended):
#   (use defaults — DeepSeek preprocessing + GPT-4o sim/report)
#
# BEST QUALITY (~$0.58/prediction, all GPT-4o):
#   ONTOLOGY_MODEL=gpt-4o
#   GRAPH_MODEL=gpt-4o
#   PROFILES_MODEL=gpt-4o
#
# CLAUDE FOR REASONING (~$0.55/prediction):
#   SIMULATION_MODEL=claude-sonnet-4-20250514
#   ANTHROPIC_API_KEY=your-key
#
# GEMINI BUDGET (~$0.10/prediction):
#   SIMULATION_MODEL=gemini-2.5-flash
#   REPORT_MODEL=gemini-2.5-flash
#   GEMINI_API_KEY=your-key
